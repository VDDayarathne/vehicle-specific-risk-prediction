##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh does
#       not comply, but you have some other compliant shell available, use it as
#       the first line of this script, e.g. as #!/bin/bash
#
#   (2) Put the GRADLE_HOME variable in your environment if you want to use a
#       location other than the default (which is the parent of this
#       validation script).
#
#   (3) You should call this script from the directory where the build.gradle or
#       settings.gradle file is located as this script will look for it.
#
#   GRADLE_HOME - Location of the GRADLE installation to use
#
##############################################################################

# Try to locate JAVA_HOME.
if [ -n "$JAVA_HOME" ] ; then
    JAVA_HOME_UPPER=`echo "$JAVA_HOME" | tr '[:lower:]' '[:upper:]'`
fi

# Express silent option as function.
function expressionoption() {
    exit "$1"
}

# Escape application args
save () {
    for i do printf %s\\n "$i" | sed "s/'/'\\\\''/g;1s/^/'/;\$s/\$/' \\\\/" ; done
    echo " "
}
APP_ARGS=$(save "$@")

# Collect all arguments for the java command.
# In Gradle builds, if GRADLE_OPTS contains multiple words, you must quote the word or use \
# to escape any of the spaces. However, this is not needed because it uses the CLI approach.

# Default JVM memory settings.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Which java executable to use?
if [ -z "$JAVA_EXE" ] ; then
    if [ -z "$JAVA_HOME" ] ; then
        JAVA_EXE="java"
    else
        if [ ! -e "$JAVA_HOME/jre/sh/java" ] ; then
            # IBM's JDK on AIX uses strange locations for the executables
            JAVA_EXE="$JAVA_HOME/bin/java"
        else
            JAVA_EXE="$JAVA_HOME/jre/sh/java"
        fi
    fi
fi

if [ ! -x "$JAVA_EXE" ] ; then
    echo "Error: JAVA_HOME is not defined correctly." >&2
    echo "  We cannot execute $JAVA_EXE" >&2
    exit 1
fi

if [ -z "$JAVA_HOME" ] ; then
    echo "Warning: JAVA_HOME environment variable is not set."
fi

CLASSWORLDS_JAR=`find "$APP_HOME" -name "gradle-wrapper.jar" | head -1`
if [ -z "$CLASSWORLDS_JAR" ] ; then
    echo "Error: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
    echo "  JAVA_HOME = "$JAVA_HOME >&2
    echo "  Please set the JAVA_HOME variable in your environment to match the" >&2
    echo "  location of your Java installation." >&2
    exit 1
fi

# Now produce the altered command.
GRADLE_OPTS="$GRADLE_OPTS \"-Dorg.gradle.appname=$APP_BASE_NAME\""

exec "$JAVA_EXE" $DEFAULT_JVM_OPTS $GRADLE_OPTS -classpath "$CLASSWORLDS_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
