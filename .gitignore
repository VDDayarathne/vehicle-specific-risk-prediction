# ============================================================
#  .gitignore — Vehicle Risk Prediction Project
# ============================================================

# ── Python bytecode & caches ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Build & packaging ─────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
*.whl

# ── Test & type-check caches ──────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Environment & secrets — NEVER commit these ───────────────
.env
.env.*
!.env.example
*.local
secrets.json

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── ML model artifacts (large binaries) ──────────────────────
# Tracked separately via DVC or Git LFS if needed
models/saved_models/*.pkl
models/saved_models/*.joblib
models/pipeline_objects/*.pkl
models/pipeline_objects/*.joblib

# ── Large dataset files ───────────────────────────────────────
data/raw/*.csv
data/raw/*.xlsx
data/processed/X_train.csv
data/processed/X_test.csv
data/processed/y_train.csv
data/processed/y_test.csv

# ── Frontend build artifacts ──────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/build/
frontend/.cache/

# ── Backend runtime ───────────────────────────────────────────
backend/__pycache__/
backend/.pytest_cache/

# ── Outputs (regeneratable) ───────────────────────────────────
outputs/

# ── Misc ──────────────────────────────────────────────────────
restructure_project.ps1
