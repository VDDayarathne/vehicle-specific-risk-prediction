# ============================================================
# .env.example — copy this to .env and fill in your values
# NEVER commit the actual .env file to git!
# ============================================================

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://kaduguard:kaduguard@db:5432/kaduguard

# ── JWT Authentication ────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase Cloud Messaging (FCM) ────────────────────────────
# Path to Firebase service account JSON file or the JSON content itself
FIREBASE_SERVICE_ACCOUNT_KEY=
FCM_DEFAULT_TOPIC=kaduguard-alerts

# ── CORS — comma-separated list of allowed frontend origins ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── External API Keys ─────────────────────────────────────────
# OpenWeatherMap (optional — OpenMeteo is used by default, no key needed)
OPENWEATHER_API_KEY=your_openweathermap_key_here

# Google Maps (for route suggestions feature)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── Database (future use) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kaduguard
